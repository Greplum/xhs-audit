{
  "buildCommand": "npm run build",
  "functions": {
    "api/xhs/index.ts": {
      "runtime": "@vercel/node@3.2.0",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/xhs",
      "dest": "/api/xhs/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}